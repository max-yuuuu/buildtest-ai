#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
COMPOSE_BASE_FILE="${ROOT_DIR}/compose.base.yml"
COMPOSE_DEV_FILE="${ROOT_DIR}/compose.dev.yml"
COMPOSE_PROD_FILE="${ROOT_DIR}/compose.prod.yml"
INFRA_COMPOSE_FILE="${ROOT_DIR}/compose.infra.yml"

info() { printf '%s\n' "$*"; }
err() { printf '%s\n' "$*" >&2; }

usage() {
  cat <<'EOF'
Usage:
  scripts/dev <command> [args...]

Commands:
  infra                 Start postgres/redis/qdrant via docker compose
  dev                   Start full development compose stack (base + dev)
  prod                  Start full production compose stack (base + prod)
  backend               Start backend on host (uvicorn --reload)
  worker                Start celery worker on host
  frontend              Start frontend on host (pnpm dev)
  up                    Start infra + backend(host) + worker(host) + frontend(host)
  full                  Alias of dev
  logs [service]        Tail docker compose logs (full compose by default)
  doctor                Verify infra connectivity (postgres/redis/qdrant)
  validate-compose      Validate infra/dev/prod compose configurations
  print-env             Print resolved key env values

Environment files (loaded in order, later overrides earlier):
  env/common.env
  .env
  env/<profile>.env

Profiles used by commands:
  backend   -> env/dev.host.env
  worker    -> env/dev.host.env
  frontend  -> env/dev.host.env
  up        -> env/dev.host.env
  dev/prod  -> docker compose env_file (env/dev.docker.env or env/prod.env)
EOF
}

trim() {
  local s="$1"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s' "$s"
}

load_env_file() {
  local file="$1"
  [[ -f "$file" ]] || return 0

  while IFS= read -r line || [[ -n "$line" ]]; do
    line="$(trim "$line")"
    [[ -z "$line" ]] && continue
    [[ "$line" == \#* ]] && continue

    if [[ "$line" == export\ * ]]; then
      line="${line#export }"
      line="$(trim "$line")"
    fi

    [[ "$line" == *"="* ]] || continue
    local key="${line%%=*}"
    local val="${line#*=}"
    key="$(trim "$key")"
    val="$(trim "$val")"

    if [[ "$val" == \"*\" && "$val" == *\" ]]; then
      val="${val:1:${#val}-2}"
    elif [[ "$val" == \'*\' && "$val" == *\' ]]; then
      val="${val:1:${#val}-2}"
    fi

    if [[ -n "$key" ]]; then
      export "${key}=${val}"
    fi
  done < "$file"
}

load_env_profiles() {
  load_env_file "${ROOT_DIR}/env/common.env"
  load_env_file "${ROOT_DIR}/.env"
  for profile in "$@"; do
    load_env_file "${ROOT_DIR}/env/${profile}.env"
  done
  normalize_path_env
}

normalize_path_env() {
  # Keep backend and celery worker aligned even when launched from different cwd.
  # Relative UPLOAD_DIR is always resolved from repository root.
  if [[ -n "${UPLOAD_DIR-}" && "${UPLOAD_DIR}" != /* ]]; then
    UPLOAD_DIR="${ROOT_DIR}/${UPLOAD_DIR#./}"
    export UPLOAD_DIR
  fi
}

ensure_profile_file() {
  local file="${ROOT_DIR}/env/${1}.env"
  local example="${file}.example"
  if [[ ! -f "$file" && -f "$example" ]]; then
    err "Missing ${file} (copy from ${example})"
    err "  cp ${example} ${file}"
    exit 1
  fi
}

require_cmd() {
  local cmd="$1"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    err "Missing required command: ${cmd}"
    exit 1
  fi
}

ensure_backend_deps() {
  require_cmd uv
  (
    cd "${ROOT_DIR}/backend"
    # This project currently pins runtime deps in requirements.txt (not pyproject).
    # Ensure uv's environment has them before running alembic/uvicorn/celery.
    uv pip install -r requirements.txt >/dev/null
  )
}

docker_infra() {
  require_cmd docker
  docker compose -f "$INFRA_COMPOSE_FILE" up -d
}

docker_dev() {
  require_cmd docker
  docker compose -f "$COMPOSE_BASE_FILE" -f "$COMPOSE_DEV_FILE" up --build
}

docker_prod() {
  require_cmd docker
  docker compose -f "$COMPOSE_BASE_FILE" -f "$COMPOSE_PROD_FILE" up --build -d
}

validate_compose() {
  require_cmd docker
  docker compose -f "$INFRA_COMPOSE_FILE" config --quiet
  docker compose -f "$COMPOSE_BASE_FILE" -f "$COMPOSE_DEV_FILE" config --quiet
  docker compose -f "$COMPOSE_BASE_FILE" -f "$COMPOSE_PROD_FILE" config --quiet
  info "OK: compose.infra/dev/prod configurations are valid"
}

cmd_print_env() {
  info "BACKEND_URL=${BACKEND_URL-}"
  info "DATABASE_URL=${DATABASE_URL-}"
  info "REDIS_URL=${REDIS_URL-}"
  info "CELERY_BROKER_URL=${CELERY_BROKER_URL-}"
  info "CELERY_RESULT_BACKEND=${CELERY_RESULT_BACKEND-}"
  info "QDRANT_URL=${QDRANT_URL-}"
  info "UPLOAD_DIR=${UPLOAD_DIR-}"
  info "NEXTAUTH_URL=${NEXTAUTH_URL-}"
}

cmd_backend() {
  ensure_profile_file dev.host
  load_env_profiles dev.host
  validate_address_mode host
  ensure_backend_deps
  (
    cd "${ROOT_DIR}/backend"
    uv run alembic upgrade head
    exec uv run uvicorn app.main:app --reload --host 0.0.0.0 --port 8000
  )
}

cmd_worker() {
  ensure_profile_file dev.host
  load_env_profiles dev.host
  validate_address_mode host
  ensure_backend_deps
  (
    cd "${ROOT_DIR}/backend"
    exec uv run celery -A app.core.celery_app worker -l info
  )
}

cmd_frontend() {
  ensure_profile_file dev.host
  load_env_profiles dev.host
  validate_address_mode host
  require_cmd pnpm
  (
    cd "${ROOT_DIR}/frontend"
    exec pnpm dev
  )
}

cmd_logs() {
  require_cmd docker
  local service="${1-}"
  if [[ -n "$service" ]]; then
    docker compose -f "$COMPOSE_BASE_FILE" -f "$COMPOSE_DEV_FILE" logs -f "$service"
  else
    docker compose -f "$COMPOSE_BASE_FILE" -f "$COMPOSE_DEV_FILE" logs -f
  fi
}

cmd_doctor() {
  require_cmd docker
  require_cmd curl

  info "Checking docker infra containers..."
  docker compose -f "$INFRA_COMPOSE_FILE" ps

  info "Checking Postgres connectivity..."
  docker compose -f "$INFRA_COMPOSE_FILE" exec -T postgres \
    psql -U buildtest -d buildtest -c "SELECT 1;" >/dev/null
  info "OK: Postgres"

  info "Checking Redis connectivity..."
  local redis_ping
  redis_ping="$(docker compose -f "$INFRA_COMPOSE_FILE" exec -T redis redis-cli ping | tr -d '\r')"
  if [[ "$redis_ping" != "PONG" ]]; then
    err "Redis ping failed: ${redis_ping}"
    exit 1
  fi
  info "OK: Redis"

  info "Checking Qdrant connectivity..."
  if curl -fsS "http://localhost:6333/healthz" >/dev/null; then
    info "OK: Qdrant (/healthz)"
  elif curl -fsS "http://localhost:6333/collections" >/dev/null; then
    info "OK: Qdrant (/collections)"
  else
    err "Qdrant health check failed at localhost:6333"
    exit 1
  fi

  info "Checking active vector config probe via app layer..."
  ensure_profile_file dev.host
  load_env_profiles dev.host
  validate_address_mode host
  ensure_backend_deps
  (
    cd "${ROOT_DIR}/backend"
    PYTHONPATH=. uv run python scripts/probe_active_vector_runtime.py
  )
}

cmd_up() {
  ensure_profile_file dev.host
  docker_infra

  info "Starting backend(host) + worker(host) + frontend(host). Press Ctrl+C to stop."

  load_env_profiles dev.host
  validate_address_mode host
  cmd_print_env
  ensure_backend_deps

  local backend_pid=""
  local worker_pid=""
  local frontend_pid=""

  cleanup() {
    if [[ -n "${frontend_pid}" ]] && kill -0 "${frontend_pid}" >/dev/null 2>&1; then
      kill "${frontend_pid}" >/dev/null 2>&1 || true
    fi
    if [[ -n "${backend_pid}" ]] && kill -0 "${backend_pid}" >/dev/null 2>&1; then
      kill "${backend_pid}" >/dev/null 2>&1 || true
    fi
    if [[ -n "${worker_pid}" ]] && kill -0 "${worker_pid}" >/dev/null 2>&1; then
      kill "${worker_pid}" >/dev/null 2>&1 || true
    fi
  }
  trap cleanup EXIT INT TERM

  (
    cd "${ROOT_DIR}/backend"
    uv run alembic upgrade head
    exec uv run uvicorn app.main:app --reload --host 0.0.0.0 --port 8000
  ) &
  backend_pid="$!"

  (
    cd "${ROOT_DIR}/backend"
    exec uv run celery -A app.core.celery_app worker -l info
  ) &
  worker_pid="$!"

  (
    cd "${ROOT_DIR}/frontend"
    exec pnpm dev
  ) &
  frontend_pid="$!"

  wait "${backend_pid}" "${frontend_pid}"
}

main() {
  local cmd="${1-}"
  shift || true

  case "$cmd" in
    infra)
      docker_infra
      ;;
    dev)
      docker_dev
      ;;
    prod)
      docker_prod
      ;;
    backend)
      cmd_backend
      ;;
    worker)
      cmd_worker
      ;;
    frontend)
      cmd_frontend
      ;;
    up)
      cmd_up
      ;;
    full)
      docker_dev
      ;;
    logs)
      cmd_logs "$@"
      ;;
    doctor)
      cmd_doctor
      ;;
    validate-compose)
      validate_compose
      ;;
    print-env)
      load_env_profiles dev.host
      cmd_print_env
      ;;
    -h|--help|help|"")
      usage
      ;;
    *)
      err "Unknown command: ${cmd}"
      usage
      exit 1
      ;;
  esac
}

validate_address_mode() {
  local mode="$1"
  if [[ "$mode" != "host" ]]; then
    return 0
  fi

  # 本机直连 Docker 里的 infra 时，只允许 loopback，避免误用 compose 服务名导致连不上。
  # 同时接受 127.0.0.1（常见 .env 写法），与 localhost 等价。
  local db="${DATABASE_URL-}"
  if [[ "$db" != *"@localhost:"* && "$db" != *"@127.0.0.1:"* ]]; then
    err "DATABASE_URL must use @localhost: or @127.0.0.1: as DB host when app runs on host (see env/dev.host.env.example)"
    exit 1
  fi

  local redis="${REDIS_URL-}"
  if [[ "$redis" != redis://localhost:* && "$redis" != redis://127.0.0.1:* ]]; then
    err "REDIS_URL must be redis://localhost:... or redis://127.0.0.1:... when app runs on host"
    exit 1
  fi

  local qdrant="${QDRANT_URL-}"
  if [[ "$qdrant" != http://localhost:* && "$qdrant" != http://127.0.0.1:* ]]; then
    err "QDRANT_URL must be http://localhost:... or http://127.0.0.1:... when app runs on host"
    exit 1
  fi

  local be="${BACKEND_URL-}"
  if [[ "$be" != http://localhost:* && "$be" != http://127.0.0.1:* ]]; then
    err "BACKEND_URL must be http://localhost:... or http://127.0.0.1:... when frontend runs on host"
    exit 1
  fi
}

main "$@"

