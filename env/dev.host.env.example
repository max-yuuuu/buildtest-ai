# App runs on host, infra in docker.
# make frontend / make backend 会校验：DB/Redis/Qdrant/BACKEND 须指向 localhost 或 127.0.0.1（勿用 compose 服务名）。
DATABASE_URL=postgresql+asyncpg://buildtest:buildtest@localhost:5432/buildtest
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
QDRANT_URL=http://localhost:6333
BACKEND_URL=http://localhost:8000
