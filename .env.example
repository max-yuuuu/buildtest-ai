# ==============================================================================
# BuildTest AI — 环境变量模板
# 复制为 .env 并填入真实值。.env 已在 .gitignore 中,切勿提交。
# 详细说明见 KEYS.md
# ==============================================================================

# ---------- NextAuth ----------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

GITHUB_ID=
GITHUB_SECRET=

GOOGLE_ID=
GOOGLE_SECRET=

RESEND_API_KEY=
# ---------- 应用加密主密钥(Fernet, 44 char base64) ----------
# 生成:python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=


# ---------- 测试模式(CI 中置 True) ----------
CELERY_TASK_ALWAYS_EAGER=False

# ---------- 文件上传目录 ----------
# 本机开发建议使用相对路径(如 ./uploads)；容器环境可设为 /app/uploads
UPLOAD_DIR=./uploads


# ---------- 邮件服务(Resend) ----------
RESEND_API_KEY=
